# AutoPrint .gitignore

# 依赖
node_modules/
package-lock.json
yarn.lock

# 临时文件
*.log
*.tmp
*.bak
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# 构建输出
dist/
build/
out/

# 环境变量
.env
.env.local
.env.production

# 系统文件
nul
nul*

# WorkBuddy
.workbuddy/
!.workbuddy/memory/MEMORY.md

# Dev scripts & tools (本地开发工具，不需要入库)
gen_*.py
gen_*.js
generate_*.js
parse_csv.py
test_rls.py
upload_to_supabase.py

# SQL data files (数据导入脚本，不需要入库)
insert_final*.sql
insert_sql.txt

# Temp JSON data (临时数据，不需要入库)
package.json
project_items.json
query*.json
records_to_upload.json
result.json
